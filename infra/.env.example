# PostgreSQL
POSTGRES_PASSWORD=tbd_dev_password

# Active Directory / LDAP
AD_LDAP_URL=ldap://your-ad-server.example.com:389
AD_BASE_DN=DC=example,DC=com
AD_BIND_DN=CN=svc-tbd,OU=Service Accounts,DC=example,DC=com
AD_BIND_PASSWORD=your-bind-password

# API
SECRET_KEY=change-me-in-production
# CORS — only needed for direct api.dev.sdc.cpp access; same-origin /api proxy doesn't need it
CORS_ORIGINS=https://dev.sdc.cpp

# Secrets Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SECRETS_ENCRYPTION_KEY=

# Registry
REGISTRY_URL=http://localhost:5000
REGISTRY_IP=
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# GitHub OAuth (user account linking)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Deploy Queue
DEPLOY_MAX_CONCURRENT=2
DEPLOY_QUEUE_MAX_SIZE=50

# Proxmox
PROXMOX_API_URL=https://your-proxmox-host:8006
PROXMOX_VERIFY_SSL=false
PROXMOX_TOKEN_ID=tbd@pve!tbd-api
PROXMOX_TOKEN_SECRET=

# OCI Conversion
OCI_WORK_DIR=/var/lib/tbd/oci

# Networking (IPs for firewall allow-lists)
NGINX_INGRESS_IP=
PLATFORM_API_IP=
NFS_SERVER_IP=
INTERNAL_DNS_IP=

# Domain scheme
# Base domain suffix: deploys are served at <deployid>.<username>.<suffix>
# Platform UI:   <suffix>        (e.g. dev.sdc.cpp)
# Platform API:  api.<suffix>    (e.g. api.dev.sdc.cpp)
# Registry:      registry.<suffix> (e.g. registry.dev.sdc.cpp)
DEPLOY_DOMAIN_SUFFIX=dev.sdc.cpp

# Web UI
# /api routes through nginx on the same origin — no CORS needed
NEXT_PUBLIC_API_URL=/api

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=tbd_admin
GRAFANA_ROOT_URL=http://localhost:3001
